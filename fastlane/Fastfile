default_platform(:ios)

api_key = app_store_connect_api_key(
    key_id: "XS46YFPT8Z",
    issuer_id: "cfc677ea-56ba-4073-b7dc-8b212a2be9b1",
    key_filepath: "~/Downloads/AuthKey_XS46YFPT8Z.p8"
)

lane :build do
  sync_certificates()
  increment_build_number()
  # Compile the app and save the build at the folder "Builds/"
  gym()
end

lane :beta do
  build()
  # Upload the build to Testflight
  pilot()
end

lane :sync_certificates do
  # Download the certificates/profiles
  match(readonly: true, api_key: api_key, type: "appstore")
end
